\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces TDDFT spectroscopy workflow in VIAMD. The interactive electronic spectrum is connected to a charge-transfer visualization for the fourth excited state of the TQ system, represented through the difference between attachment and detachment densities.\relax }}{12}{figure.caption.10}\protected@file@percent }
\newlabel{fig:tddft}{{5}{12}{TDDFT spectroscopy workflow in VIAMD. The interactive electronic spectrum is connected to a charge-transfer visualization for the fourth excited state of the TQ system, represented through the difference between attachment and detachment densities.\relax }{figure.caption.10}{}}
