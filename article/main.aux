\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the VIAMD--VeloxChem interface for interactive quantum-chemical analysis. The central spatial view displays the molecular structure together with an electron-density isosurface, while the surrounding panels show the Response window for spectral analysis, the Representations window for configuring electronic visualizations, the Transition Analysis window for attachment--detachment and fragment-based excited-state analysis, and the Orbital Grid for comparative inspection of multiple orbitals.\relax }}{4}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{4}{Overview of the VIAMD--VeloxChem interface for interactive quantum-chemical analysis. The central spatial view displays the molecular structure together with an electron-density isosurface, while the surrounding panels show the Response window for spectral analysis, the Representations window for configuring electronic visualizations, the Transition Analysis window for attachment--detachment and fragment-based excited-state analysis, and the Orbital Grid for comparative inspection of multiple orbitals.\relax }{figure.caption.2}{}}
\citation{Bader1990}
