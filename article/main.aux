\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Orbital Grid view for comparing multiple orbitals or density-derived quantities side by side. The window complements the main spatial representations by providing a compact overview of orbital shapes, phases, energies, occupations, and spin channels.\relax }}{10}{figure.caption.7}\protected@file@percent }
\newlabel{fig:orbital-grid}{{4}{10}{Orbital Grid view for comparing multiple orbitals or density-derived quantities side by side. The window complements the main spatial representations by providing a compact overview of orbital shapes, phases, energies, occupations, and spin channels.\relax }{figure.caption.7}{}}
